let scMetric = 'pts';

function setSCMetric(metric, team, season) {
  scMetric = metric;
  document.querySelectorAll('.sc-tab').forEach(b => b.classList.remove('active'));
  const el = document.getElementById('sct-' + metric);
  if (el) el.classList.add('active');
  buildSeasonChart(metric, team, season);
}

function buildSeasonChart(metric, team, season) {
  const container = document.getElementById('seasonChart');
  if (!container) return;
  container.innerHTML = '';

  const rows = getRawStandings()[season];
  if (!rows) return;

  // For GD, find the absolute max to scale bars
  let maxVal, minVal;
  if (metric === 'gd') {
    const vals = rows.map(r => r[6] - r[7]);
    maxVal = Math.max(...vals);
    minVal = Math.min(...vals);
  } else {
    const key = { pts: 8, gf: 6, ga: 7 }[metric];
    maxVal = Math.max(...rows.map(r => r[key]));
    minVal = 0;
  }
  const range = maxVal - minVal || 1;

  for (const row of rows) {
    const [pos, tname, p, w, d, l, gf, ga, pts] = row;
    const gd = gf - ga;
    const val = metric === 'pts' ? pts : metric === 'gf' ? gf : metric === 'ga' ? ga : gd;
    const isSelected = tname === team;
    const tcolor = TEAM_COLORS[tname] || '#888';
    const posBg = positionColor(pos, rows.length);

    // Bar width: for GD, split around zero
    let barPct, barOffset = 0;
    if (metric === 'gd') {
      const zeroAt = (-minVal / range) * 100;
      if (val >= 0) {
        barOffset = zeroAt;
        barPct = (val / range) * 100;
      } else {
        barPct = (Math.abs(val) / range) * 100;
        barOffset = zeroAt - barPct;
      }
    } else {
      barPct = ((val - minVal) / range) * 100;
    }

    // Bar color: selected team uses team color, others use position color
    const barColor = isSelected ? tcolor : posBg;

    const scRow = document.createElement('div');
    scRow.className = 'sc-row' + (isSelected ? ' sc-selected' : '');

    const shortName = shortTeamName(tname);

    scRow.innerHTML = `
      <span class="sc-pos">${pos}</span>
      <div class="sc-bar-wrap">
        <div class="sc-bar-bg">
          <div class="sc-bar" style="width:${barPct}%;margin-left:${barOffset}%;background:${barColor};opacity:${isSelected?1:0.55};"></div>
        </div>
        <div class="sc-name-val">
          <span class="sc-name" style="color:${isSelected?'#fff':'#cbd5e1'};font-weight:${isSelected?700:400};cursor:pointer;" onclick="openPanel('${tname}', '${season}')">${isSelected ? '▶ ' : ''}${shortName}</span>
          <span class="sc-val" style="color:${metric==='gd'&&val>0?'#4ade80':metric==='gd'&&val<0?'#f87171':'#e2e8f0'}">${val > 0 && metric === 'gd' ? '+' : ''}${val}</span>
        </div>
      </div>
      <span></span>
    `;
    container.appendChild(scRow);
  }
}

// ESPN overrides for teams whose names aren't a substring of the ESPN display name

function matchesESPNTeam(myTeam, espnDisplayName) {
  const espn = espnDisplayName.toLowerCase();
  const my = (ESPN_NAMES[myTeam] || myTeam).toLowerCase();
  return espn === my || espn.includes(my);
}

function espnSeasonDates(season) {
  // "2024-25" → { from:"20240801", to:"20250630" }
  const [a, b] = season.split('-');
  const endYear = parseInt(b) < 30 ? 2000 + parseInt(b) : 1900 + parseInt(b);
  return { from: `${a}0801`, to: `${endYear}0630` };
}

async function fetchRealMatches(team, season) {
  // ESPN data is only accurate for 2003 onwards
  const [startYear] = season.split('-');
  if (parseInt(startYear) < 2003) return null;

  const { from, to } = espnSeasonDates(season);
  try {
    const r = await fetchTimeout(
      `https://site.api.espn.com/apis/site/v2/sports/soccer/eng.1/scoreboard?dates=${from}-${to}&limit=500`,
      8000
    );
    if (!r.ok) return null;
    const j = await r.json();
    if (!j.events?.length) return null;

    const games = j.events
      .map(ev => {
        const comp = ev.competitions?.[0];
        const home = comp?.competitors?.find(c => c.homeAway === 'home');
        const away = comp?.competitors?.find(c => c.homeAway === 'away');
        if (!home || !away) return null;
        const isHome = matchesESPNTeam(team, home.team?.displayName || '');
        const isAway = !isHome && matchesESPNTeam(team, away.team?.displayName || '');
        if (!isHome && !isAway) return null;
        const myComp  = isHome ? home : away;
        const oppComp = isHome ? away : home;
        const gf = parseInt(myComp.score);
        const ga = parseInt(oppComp.score);
        if (isNaN(gf) || isNaN(ga)) return null;
        const opp = (oppComp.team?.displayName || '').replace(/ FC$/, '');
        return {
          ha: isHome ? 'H' : 'A',
          result: gf > ga ? 'W' : gf < ga ? 'L' : 'D',
          gf, ga, opp,
          date: ev.date?.split('T')[0] || '',
          espnId: ev.id,
          homeTeam: (home.team?.displayName || '').replace(/ FC$/, ''),
          awayTeam: (away.team?.displayName || '').replace(/ FC$/, ''),
          homeGoalStr: '', awayGoalStr: '',
          isHome,
        };
      })
      .filter(Boolean)
      .sort((a, b) => new Date(a.date) - new Date(b.date));

    return games.length >= 10 ? games : null;
  } catch { return null; }
}

function parseGoalDetails(str) {
  if (!str || !str.trim()) return [];
  return str.split(';')
    .map(p => p.trim()).filter(Boolean)
    .map(p => {
      // formats: "45':Name", "45'Name", "90+2':Name"
      const m = p.match(/^(\d+)(?:\+\d+)?['\s:]+(.+)$/);
      if (!m) return null;
      let name = m[2].trim()
        .replace(/\s*\(pen(?:alty)?\)\s*/i, ' ✦')
        .replace(/\s*\(o\.?g\.?\)\s*/i, ' (OG)');
      return { time: parseInt(m[1]), name };
    })
    .filter(Boolean)
    .sort((a, b) => a.time - b.time);
}

function parseToGoals(homeStr, awayStr, isHome) {
  const my  = parseGoalDetails(isHome ? homeStr : awayStr).map(g => ({ ...g, side: 'my'  }));
  const opp = parseGoalDetails(isHome ? awayStr : homeStr).map(g => ({ ...g, side: 'opp' }));
  const all = [...my, ...opp].sort((a, b) => a.time - b.time);
  return all.length ? all : null;
}

async function fetchESPNGoals(match) {
  try {
    let espnId = match.espnId || null;

    // If no stored ID, find it from the scoreboard on the match date
    if (!espnId && match.date) {
      const dateParam = match.date.replace(/-/g, '');
      const sbRes = await fetchTimeout(
        `https://site.api.espn.com/apis/site/v2/sports/soccer/eng.1/scoreboard?dates=${dateParam}`,
        6000
      );
      const sb = await sbRes.json();
      const myWord  = ((match.isHome ? match.homeTeam : match.awayTeam) || '').split(' ')[0].toLowerCase();
      const oppWord = (match.opp || '').split(' ')[0].toLowerCase();
      for (const ev of (sb.events || [])) {
        const names = (ev.competitions?.[0]?.competitors || [])
          .map(c => (c.team?.displayName || '').toLowerCase());
        const hasMe  = names.some(n => n.includes(myWord));
        const hasOpp = oppWord.length < 2 || names.some(n => n.includes(oppWord));
        if (hasMe && hasOpp) { espnId = ev.id; break; }
      }
    }
    if (!espnId) return null;

    const smRes = await fetchTimeout(
      `https://site.api.espn.com/apis/site/v2/sports/soccer/eng.1/summary?event=${espnId}`,
      6000
    );
    const sm = await smRes.json();

    const myWord = ((match.isHome ? match.homeTeam : match.awayTeam) || '').split(' ')[0].toLowerCase();
    const goals = [];
    for (const ev of (sm.keyEvents || [])) {
      const isGoal = ev.scoringPlay === true
        || ev.type?.type === 'goal'
        || ev.type?.id === '70' || ev.type?.id === '58'
        || (ev.type?.text || '').toLowerCase() === 'goal';
      if (!isGoal) continue;
      const mins = parseInt(ev.clock?.displayValue) || Math.round((ev.clock?.value || 0) / 60);
      const name = ev.participants?.[0]?.athlete?.displayName
        || ev.participants?.[0]?.athlete?.shortName
        || '?';
      const teamName = (ev.team?.displayName || '').toLowerCase();
      goals.push({ time: mins, name, side: teamName.includes(myWord) ? 'my' : 'opp' });
    }
    return goals.length ? goals.sort((a, b) => a.time - b.time) : [];
  } catch { return null; }
}

// Normalize team names to match HISTORICAL_MATCHES data
function normalizeTeamNameForHistorical(team) {
  const maps = {
    'Leicester City': 'Leicester',
    'Wolverhampton Wanderers': 'Wolverhampton',
    'Wolverhampton': 'Wolverhampton',
    'Brighton and Hove Albion': 'Brighton',
    'Brighton': 'Brighton',
    'West Bromwich Albion': 'West Brom',
    'WBA': 'West Brom',
    'Luton Town': 'Luton',
    'Nottingham Forest': 'Nott\'m Forest',
  };
  return maps[team] || team;
}

// Get match data from HISTORICAL_MATCHES if available
function getHistoricalMatchData(season, homeTeam, awayTeam) {
  // Try recent historical data first (2019-24)
  let matches = HISTORICAL_MATCHES?.[season];

  // Fall back to pre-2003 data (2002-03)
  if (!matches) {
    matches = HISTORICAL_MATCHES_PRE2003?.[season];
  }

  if (!matches) return null;

  const h = normalizeTeamNameForHistorical(homeTeam);
  const a = normalizeTeamNameForHistorical(awayTeam);

  // Find match in historical data
  for (const m of matches) {
    if (m.h === h && m.a === a) {
      return { goals: m.hg, goalsAgainst: m.ag, goals_for: m.hg, goals_against: m.ag, date: m.d };
    }
  }
  return null;
}

async function handleGameClick(e, idx) {
  e.stopPropagation();
  document.querySelectorAll('.game-popup').forEach(el => el.remove());

  let match = window._mrMatches?.[idx];
  if (!match) return;

  // Try to enrich match data with historical scores if available
  const season = match.season || match.seasonKey;
  if (season && HISTORICAL_MATCHES?.[season]) {
    const historicalData = getHistoricalMatchData(season, match.homeTeam, match.awayTeam);
    if (historicalData) {
      match.gf = match.isHome ? historicalData.goals : historicalData.goalsAgainst;
      match.ga = match.isHome ? historicalData.goalsAgainst : historicalData.goals;
      match.historicalMatch = true;
    }
  }

  const popup = document.createElement('div');
  popup.className = 'game-popup';

  // Position near the cell, keep within viewport
  const cr = e.currentTarget.getBoundingClientRect();
  const pw = 240;
  let left = cr.right + 8;
  let top  = cr.top;
  if (left + pw > window.innerWidth - 8) left = cr.left - pw - 8;
  if (top + 260 > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 268);
  popup.style.left = left + 'px';
  popup.style.top  = top  + 'px';

  const homeTeam = match.homeTeam || match.h;
  const awayTeam = match.awayTeam || match.a;
  const isHome = match.isHome !== undefined ? match.isHome : (match.ha === 'H');
  const venue    = match.ha === 'H' ? 'Home' : 'Away';
  const resultTx = match.result === 'W' ? 'Win' : match.result === 'D' ? 'Draw' : match.result === 'U' ? 'Upcoming' : 'Loss';
  const resCol   = match.result === 'W' ? '#4ade80' : match.result === 'D' ? '#fbbf24' : match.result === 'U' ? '#6b7280' : '#f87171';
  const myTeam   = isHome ? homeTeam : awayTeam;
  const oppTeam  = match.opp || (isHome ? awayTeam : homeTeam) || '?';
  const myColor  = TEAM_COLORS[myTeam] || '#888';
  const oppColor = TEAM_COLORS[oppTeam] || '#888';
  const isUpcoming = match.result === 'U';

  popup.innerHTML = `
    <div class="gp-topbar">
      <span class="gp-meta">${match.date ? match.date : 'TBD'}${match.date ? ' · ' : ' '}${venue}</span>
      <button class="gp-xbtn" onclick="this.closest('.game-popup').remove()">✕</button>
    </div>
    <div class="gp-scoreline">
      ${isUpcoming ? `
        <div style="color:#06b6d4; font-weight:600; padding: 8px 0; font-size: 14px;">⏰ Upcoming Match</div>
      ` : `
        <div class="gp-score-big">${match.gf}<span style="color:#4b5563;font-weight:300;padding:0 4px">–</span>${match.ga}</div>
      `}
      <div class="gp-teams-row">
        <span class="ht" style="display:flex; flex-direction:column; align-items:center; gap:4px;">
          ${getTeamLogo(match.isHome ? myTeam : oppTeam) ? `<img src="${getTeamLogo(match.isHome ? myTeam : oppTeam)}" style="width:20px; height:20px; object-fit:contain;" alt="${match.isHome ? myTeam : oppTeam}"/>` : ''}
          ${match.isHome ? (myTeam || '—') : (oppTeam || '—')}
        </span>
        <span style="color:${resCol};font-weight:700">${resultTx}</span>
        <span class="at" style="display:flex; flex-direction:column; align-items:center; gap:4px; justify-content:center;">
          ${getTeamLogo(match.isHome ? oppTeam : myTeam) ? `<img src="${getTeamLogo(match.isHome ? oppTeam : myTeam)}" style="width:20px; height:20px; object-fit:contain;" alt="${match.isHome ? oppTeam : myTeam}"/>` : ''}
          ${match.isHome ? (oppTeam || '—') : (myTeam || '—')}
        </span>
      </div>
    </div>
    ${!isUpcoming ? `<div class="gp-divider"></div>` : ''}
    <div class="gp-goal-list" id="gpGoals">
      ${isUpcoming ? `<div style="color:#9ca3af; font-size: 12px; text-align: center; padding: 8px;">Match details will be available after kickoff</div>` : `<div class="gp-empty"><span class="api-spinner"></span></div>`}
    </div>
  `;

  document.body.appendChild(popup);

  const goalDiv = popup.querySelector('#gpGoals');
  if (!goalDiv || !popup.isConnected) return;

  let goals = null;

  // 1. Use goal strings already stored from the season fetch
  if (match.homeGoalStr || match.awayGoalStr) {
    goals = parseToGoals(match.homeGoalStr, match.awayGoalStr, match.isHome);
  }

  // 2. ESPN — works for all seasons ESPN covers (use stored espnId for instant lookup)
  if (!goals && (match.espnId || match.date)) {
    goals = await fetchESPNGoals(match);
  }

  if (!popup.isConnected) return;

  if (!goals || !goals.length) {
    goalDiv.innerHTML = match.gf === 0 && match.ga === 0
      ? '<div class="gp-empty">0 – 0</div>'
      : match.historicalMatch
        ? '<div class="gp-empty">Historical match — scorer data unavailable</div>'
        : !match.espnId && !match.date
          ? '<div class="gp-empty">Simulated match — select a recent season for real scorer data</div>'
          : '<div class="gp-empty">Scorer data not available for this match</div>';
    return;
  }

  goalDiv.innerHTML = goals.map(g => `
    <div class="gp-goal ${g.side === 'opp' ? 'opp' : ''}">
      <span class="gmin">${g.time}'</span>
      <span>⚽</span>
      <span class="gname">${g.name}</span>
    </div>`).join('');
}

