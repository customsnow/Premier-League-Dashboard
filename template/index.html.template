function reorderViewButtons(defaultMode) {
  const btnGroup = document.getElementById('viewButtonGroup');
  const historicalBtn = document.getElementById('view-historical');
  const liveBtn = document.getElementById('view-live');

  // Clear and rebuild in desired order
  btnGroup.innerHTML = '';

  if (defaultMode === 'historical') {
    btnGroup.appendChild(historicalBtn);
    btnGroup.appendChild(liveBtn);
  } else {
    btnGroup.appendChild(liveBtn);
    btnGroup.appendChild(historicalBtn);
  }

  // Reattach event listeners
  historicalBtn.onclick = () => setViewMode('historical');
  liveBtn.onclick = () => setViewMode('live');
}

function saveDefaultViewPreference() {
  const selectedMode = document.querySelector('input[name="default-view"]:checked').value;
  saveViewPreference(selectedMode);
  reorderViewButtons(selectedMode);
  toggleSettingsModal();
  // Switch to the selected view
  setViewMode(selectedMode);
  // Show a brief notification
  console.log(`Default view preference saved: ${selectedMode}`);
}

function getTeamLast5(teamName, matches) {
  const teamMatches = matches.filter(m => m.h === teamName || m.a === teamName).slice(-5);
  let html = '';
  teamMatches.forEach(m => {
    let result = '';
    if (m.h === teamName) {
      if (m.hg > m.ag) result = 'W';
      else if (m.hg < m.ag) result = 'L';
      else result = 'D';
    } else {
      if (m.ag > m.hg) result = 'W';
      else if (m.ag < m.hg) result = 'L';
      else result = 'D';
    }
    const bgColor = result === 'W' ? '#10b981' : result === 'D' ? '#f59e0b' : '#ef4444';
    const score = m.h === teamName ? `${m.hg}-${m.ag}` : `${m.ag}-${m.hg}`;
    html += `<div style="display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: ${bgColor}; border-radius: 4px; font-weight: 700; font-size: 11px; color: white; margin-right: 3px; title="${score}">${result}</div>`;
  });
  return html;
}

function buildLiveTable() {
  const table = calculateLiveStandings();
  const tbody = document.getElementById('tbody');
  const thead = document.getElementById('thead');
  const matches = getHistoricalMatches()[ACTIVE_SEASON] || [];

  // Clear and rebuild header
  thead.innerHTML = `
    <tr>
      <th style="position: sticky; left: 0; z-index: 60; padding: 8px; text-align: center; min-width: 35px; max-width: 35px; background: var(--surface2); border-right: 2px solid var(--accent);">Pos</th>
      <th style="position: sticky; left: 35px; z-index: 60; padding: 8px; text-align: left; min-width: 140px; background: var(--surface2); border-right: 2px solid var(--accent);">Team</th>
      <th style="padding: 8px; text-align: center;">P</th>
      <th style="padding: 8px; text-align: center;">W</th>
      <th style="padding: 8px; text-align: center;">D</th>
      <th style="padding: 8px; text-align: center;">L</th>
      <th style="padding: 8px; text-align: center;">GF</th>
      <th style="padding: 8px; text-align: center;">GA</th>
      <th style="padding: 8px; text-align: center;">GD</th>
      <th style="padding: 8px; text-align: center; font-weight: 900;">Pts</th>
      <th style="padding: 8px; text-align: center; min-width: 180px;">Last 5</th>
      <th style="padding: 8px; text-align: center; min-width: 160px;" id="lastColumnHeader">Finish</th>
    </tr>
  `;

  // Build table rows
  tbody.innerHTML = '';
  table.forEach((row, idx) => {
    const tr = document.createElement('tr');
    const posColor = positionColor(idx + 1, 20);
    const posText = idx + 1;
    const last5Html = getTeamLast5(row.team, matches);

    // Check for promotion/relegation status
    const isPromoted = isPromotedTeam(row.team, ACTIVE_SEASON);
    const isRelegated = isRelegatedTeam(row.team, ACTIVE_SEASON);
    let promotionIndicator = '';
    if (isPromoted) promotionIndicator = '<span class="promotion-icon"></span>';
    if (isRelegated) promotionIndicator = '<span class="relegation-icon"></span>';

    // Show finishing position for completed season (2025-26)
    const finishPosition = `#${posText}`;
    const positionStyle = 'color: #fbbf24; font-weight: 600;';

    tr.className = isPromoted ? 'promoted' : isRelegated ? 'relegated' : '';
    tr.innerHTML = `
      <td style="position: sticky; left: 0; z-index: 10; background: ${posColor}; color: white; font-weight: 900; padding: 8px; text-align: center; min-width: 35px; max-width: 35px; border-right: 2px solid var(--border);">${posText}</td>
      <td style="position: sticky; left: 35px; z-index: 10; background: var(--surface); color: white; font-weight: 600; padding: 8px; min-width: 140px; border-right: 2px solid var(--border);">${promotionIndicator}${row.team}</td>
      <td style="padding: 8px; text-align: center;">${row.p}</td>
      <td style="padding: 8px; text-align: center; color: #10b981;">${row.w}</td>
      <td style="padding: 8px; text-align: center; color: #f59e0b;">${row.d}</td>
      <td style="padding: 8px; text-align: center; color: #ef4444;">${row.l}</td>
      <td style="padding: 8px; text-align: center;">${row.gf}</td>
      <td style="padding: 8px; text-align: center;">${row.ga}</td>
      <td style="padding: 8px; text-align: center; font-weight: 600; color: ${row.gd > 0 ? '#10b981' : row.gd < 0 ? '#ef4444' : '#9ca3af'};">${row.gd > 0 ? '+' : ''}${row.gd}</td>
      <td style="padding: 8px; text-align: center; font-weight: 900; font-size: 1.1rem;">${row.pts}</td>
      <td style="padding: 8px; text-align: center;">${last5Html}</td>
      <td style="padding: 8px; text-align: center; ${positionStyle}">${finishPosition}</td>
    `;
    tbody.appendChild(tr);
  });

  // Remove old last 5 container if it exists
  const oldContainer = document.getElementById('last5Container');
  if (oldContainer) oldContainer.remove();
}

function filterTeams(val) {
  searchFilter = val;
  if (viewMode === 'historical') buildTable();
}

function updateLegend() {
  const leg = document.getElementById('legend');
  if (colorMode === 'position') {
    leg.innerHTML = `
      <div class="legend-item"><div class="legend-swatch" style="background:#c8a400"></div>Champion</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#1e40af"></div>Top 4 (UCL)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#065f46"></div>5–7 (Europa)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#374151"></div>Mid-table</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#7f1d1d"></div>Relegated</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#1a1d27;border:1px solid #2e3347"></div>Not in PL</div>
    `;
  } else if (colorMode === 'goals') {
    leg.innerHTML = `
      <div class="legend-item"><div class="legend-swatch" style="background:#1e3a5f"></div>Low (≤30)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#f59e0b"></div>High (100+)</div>
      <div class="legend-item" style="color:#7c8398">Number = goals scored</div>
    `;
  } else if (colorMode === 'gd') {
    leg.innerHTML = `
      <div class="legend-item"><div class="legend-swatch" style="background:#10b981"></div>+70 GD</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#374151"></div>±0</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#ef4444"></div>−70 GD</div>
      <div class="legend-item" style="color:#7c8398">Number = goal difference</div>
    `;
  } else if (colorMode === 'pts') {
    leg.innerHTML = `
      <div class="legend-item"><div class="legend-swatch" style="background:#1e1e3a"></div>Low (20pts)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:#6366f1"></div>High (100pts)</div>
      <div class="legend-item" style="color:#7c8398">Number = points</div>
    `;
  }
}

// Set --header-h CSS variable from actual rendered heights
function updateHeaderHeight() {
  const hh = (document.querySelector('header')?.offsetHeight || 0)
            + (document.querySelector('.legend')?.offsetHeight || 0);
  document.documentElement.style.setProperty('--header-h', hh + 'px');
}

// Init
// Populate league selector dropdown
populateLeagueSelector();

// Event delegation for league selection and dropdown management
document.addEventListener('click', (e) => {
  const dropdown = document.getElementById('leagueSelectorDropdown');
  const h1 = document.querySelector('header h1');

  // Handle league option clicks
  if (e.target.classList.contains('league-option')) {
    e.stopPropagation();
    const leagueId = e.target.getAttribute('data-league');
    selectLeague(leagueId);
    return;
  }

  // Close league selector on outside click
  if (!h1.contains(e.target)) {
    closeLeagueSelector();
  }
});

// Load and apply user's preferred view
const preferredView = loadViewPreference();
reorderViewButtons(preferredView);
viewMode = preferredView;

// Set the correct button as active
document.querySelectorAll('[id^="view-"]').forEach(b=>b.classList.remove('active'));
document.getElementById(`view-${viewMode}`).classList.add('active');

// Show/hide controls based on view mode
document.getElementById('searchTeam').style.display = viewMode === 'live' ? 'none' : 'block';
document.querySelectorAll('[id^="sort-"]').forEach(b=>b.parentElement.style.display = viewMode === 'live' ? 'none' : 'flex');
document.querySelectorAll('[id^="mode-"]').forEach(b=>b.parentElement.style.display = viewMode === 'live' ? 'none' : 'flex');
document.getElementById('legend').style.display = viewMode === 'live' ? 'none' : 'flex';

// Populate year dropdown (in descending order - newest first)
function populateYearDropdown() {
  const yearSelect = document.getElementById('yearSelect');
  yearSelect.innerHTML = ''; // Clear existing options
  const seasons = getSeasons();
  const seasonsDescending = [...seasons].reverse();
  seasonsDescending.forEach(season => {
    const option = document.createElement('option');
    option.value = season;
    option.textContent = season;
    yearSelect.appendChild(option);
  });
}

populateYearDropdown();

// Build the appropriate table
if (viewMode === 'live') buildLiveTable();
else buildTable();

updateHeaderHeight();
window.addEventListener('resize', updateHeaderHeight);
</script>
</body>
</html>
