async function buildMatchChart(team, season) {
  const container = document.getElementById('matchChart');
  if (!container) return;

  container.innerHTML = `<div style="color:#6b7280;font-size:11px;padding:10px 0;display:flex;align-items:center;gap:8px">
    <span class="api-spinner"></span>Loading match results…
  </div>`;

  let matches = await fetchRealMatches(team, season);
  const isReal = !!matches;
  if (!matches) matches = generateMatchData(team, season);

  // For 2025-26 season, mark upcoming fixtures as 'U' instead of treating them as unplayed
  if (season === ACTIVE_SEASON && matches.length > 0) {
    // Get actual played matches from HISTORICAL_MATCHES
    const historicalMatches = HISTORICAL_MATCHES[ACTIVE_SEASON] || [];
    const playedCount = historicalMatches.length;

    // Count actual played matches for this team
    let teamPlayedCount = 0;
    for (const m of historicalMatches) {
      if (m.h === team || m.a === team) {
        teamPlayedCount++;
      }
    }

    // Mark all matches after the played count as upcoming
    matches = matches.map((m, idx) => {
      if (idx >= teamPlayedCount) {
        // This match hasn't been played yet
        return { ...m, result: 'U', gf: 0, ga: 0 };
      }
      return m;
    });

    // Also check fixtures list to enrich upcoming match data with opponent info
    const upcomingFixtures = FIXTURES_2025_26.filter(f => teamNamesMatch(f.h, team) || teamNamesMatch(f.a, team));
    matches = matches.map((m, idx) => {
      if (m.result === 'U' && idx >= teamPlayedCount) {
        // Find matching fixture
        for (const f of upcomingFixtures) {
          const isHome = teamNamesMatch(f.h, team);
          const opponent = isHome ? f.a : f.h;
          if (m.ha === (isHome ? 'H' : 'A')) {
            return { ...m, opp: opponent, date: f.d };
          }
        }
      }
      return m;
    });
  }

  const d = teamSeasonMap[team]?.[season];
  if (!d || !matches.length) { container.innerHTML = '<p style="color:#4b5563;font-size:11px">No data available</p>'; return; }

  const hm = matches.filter(m=>m.ha==='H'), am = matches.filter(m=>m.ha==='A');
  const hw=hm.filter(m=>m.result==='W').length, hd=hm.filter(m=>m.result==='D').length, hl=hm.filter(m=>m.result==='L').length;
  const hu=hm.filter(m=>m.result==='U').length, hu_actual=hm.filter(m=>m.result==='U').length;
  const aw=am.filter(m=>m.result==='W').length, ad=am.filter(m=>m.result==='D').length, al=am.filter(m=>m.result==='L').length;
  const au=am.filter(m=>m.result==='U').length;
  const hpts=hw*3+hd, apts=aw*3+ad;

  const BG = {
    'W-H':'#166534','W-A':'#14532d',
    'D-H':'#92400e','D-A':'#78350f',
    'L-H':'#991b1b','L-A':'#7f1d1d',
    'U-H':'#374151','U-A':'#1f2937'
  };

  window._mrMatches = matches;
  window._currentTeam = team;

  let cells = '', cum = 0;
  const cumPts = [];
  for (let i=0; i<matches.length; i++) {
    const m = matches[i];
    cum += m.result==='W' ? 3 : m.result==='D' ? 1 : 0;
    cumPts.push(cum);
    const bg = BG[`${m.result}-${m.ha}`];
    const oppLine = m.opp ? ` vs ${m.opp}` : '';
    const dateLine = m.date ? ` · ${m.date}` : '';
    const resultText = m.result==='W'?'Win':m.result==='D'?'Draw':m.result==='L'?'Loss':'Upcoming';
    const scoreText = m.result==='U' ? '—' : `${m.gf}–${m.ga}`;
    const ptsText = m.result==='U' ? '—' : ` · ${cum}pts`;
    const tip = `Game ${i+1}${dateLine}${oppLine} · ${m.ha==='H'?'Home':'Away'} · ${resultText} ${scoreText}${ptsText}`;
    cells += `<div class="mr-cell" style="background:${bg}" title="${tip}" onclick="handleGameClick(event,${i})">
      <span class="mr-res">${m.result==='U'?'?':m.result}</span>
      <span class="mr-score">${scoreText}</span>
      <span class="mr-ha ${m.ha}">${m.ha}</span>
    </div>`;
  }

  const maxPts = d.pts || 1;
  let bars = '';
  for (let i=0; i<cumPts.length; i++) {
    const h = Math.round((cumPts[i]/maxPts)*30)+2;
    const m = matches[i];
    const c = m.result==='W'?'#4ade80':m.result==='D'?'#fbbf24':m.result==='U'?'#6b7280':'#f87171';
    bars += `<div class="mr-pts-bar" style="height:${h}px;background:${c};opacity:.75" title="After game ${i+1}: ${cumPts[i]}pts"></div>`;
  }

  const sourceNote = isReal
    ? `<span style="color:#22c55e">● Live data · TheSportsDB</span>`
    : `<span style="color:#6b7280">● Estimated from season record</span>`;

  // Calculate real clean sheets from match data
  if (isReal && matches.length) {
    const realCleanSheets = matches.filter(m => m.ga === 0).length;
    const cleanVal = document.getElementById('cleanSheetVal');
    if (cleanVal) {
      cleanVal.textContent = realCleanSheets;
      cleanVal.parentElement.querySelector('.lbl').textContent = 'Clean Sheets';
    }
  }

  // Adjust games count to exclude upcoming matches
  const hPlayedCount = hm.length - hu;
  const aPlayedCount = am.length - au;

  // Build record display - exclude upcoming games
  const hRecordDisplay = hu > 0 ? `${hw}W–${hd}D–${hl}L (${hu} upcoming)` : `${hw}W–${hd}D–${hl}L`;
  const aRecordDisplay = au > 0 ? `${aw}W–${ad}D–${al}L (${au} upcoming)` : `${aw}W–${ad}D–${al}L`;

  container.innerHTML = `
    <div class="mr-header">
      <div class="mr-ha-card" id="home-filter" style="cursor:pointer;transition:opacity 0.2s" onclick="filterMatches('H')">
        <div class="hac-label" style="color:#fbbf24">🏠 Home</div>
        <div class="hac-rec">${hRecordDisplay}</div>
        <div class="hac-pts">${hpts} pts · ${hPlayedCount} played</div>
      </div>
      <div class="mr-ha-card" id="away-filter" style="cursor:pointer;transition:opacity 0.2s" onclick="filterMatches('A')">
        <div class="hac-label" style="color:#93c5fd">✈ Away</div>
        <div class="hac-rec">${aRecordDisplay}</div>
        <div class="hac-pts">${apts} pts · ${aPlayedCount} played</div>
      </div>
    </div>
    <div class="mr-grid" id="match-grid">${cells}</div>
    <div class="mr-pts-strip">${bars}</div>
    <div class="mr-note" onclick="filterMatches(null)" style="cursor:pointer;color:#6b7280;transition:color 0.2s" onmouseover="this.style.color='#cbd5e1'" onmouseout="this.style.color='#6b7280'">${sourceNote} · cumulative points · gray bars = upcoming matches</div>
  `;
}

let _currentFilter = null;

function filterMatches(filterBy) {
  const grid = document.getElementById('match-grid');
  if (!grid) return;

  const cells = grid.querySelectorAll('.mr-cell');
  const matches = window._mrMatches;
  const homeFilter = document.getElementById('home-filter');
  const awayFilter = document.getElementById('away-filter');

  // Toggle: if clicking same filter, clear it; otherwise apply new filter
  if (_currentFilter === filterBy) {
    _currentFilter = null;
    filterBy = null;
  } else {
    _currentFilter = filterBy;
  }

  if (filterBy === 'H') {
    // Filter to HOME games
    homeFilter.style.opacity = '1';
    awayFilter.style.opacity = '0.5';
    cells.forEach((cell, i) => {
      cell.style.opacity = matches[i].ha === 'H' ? '1' : '0.3';
    });
  } else if (filterBy === 'A') {
    // Filter to AWAY games
    awayFilter.style.opacity = '1';
    homeFilter.style.opacity = '0.5';
    cells.forEach((cell, i) => {
      cell.style.opacity = matches[i].ha === 'A' ? '1' : '0.3';
    });
  } else {
    // Clear filter
    homeFilter.style.opacity = '1';
    awayFilter.style.opacity = '1';
    cells.forEach(cell => {
      cell.style.opacity = '1';
    });
  }
}

