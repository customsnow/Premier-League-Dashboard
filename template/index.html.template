function generateMatchData(team, season) {
  const d = teamSeasonMap[team]?.[season];
  if (!d) return [];
  const { w, d: draws, l } = d;

  // Seeded xorshift so the same team/season always produces the same sequence
  let sv = 0;
  for (const c of (team + season)) sv = (Math.imul(sv, 31) + c.charCodeAt(0)) | 0;
  sv = sv || 1;
  const rand = () => {
    sv ^= sv << 13; sv ^= sv >> 17; sv ^= sv << 5;
    return (sv >>> 0) / 4294967296;
  };

  // Realistic PL home/away split: ~60% of wins at home, ~50% draws, ~35% losses
  const clamp = (v, lo, hi) => Math.min(hi, Math.max(lo, v));
  const hw = clamp(Math.round(w     * (.55 + rand()*.1)), 0, w);
  const hd = clamp(Math.round(draws * (.45 + rand()*.1)), 0, draws);
  const hl = clamp(Math.round(l     * (.30 + rand()*.1)), 0, l);
  const aw = w - hw, ad = draws - hd, al = l - hl;

  // Score generator: produce a plausible scoreline for a given result
  const winScore  = () => { const g=clamp(Math.floor(rand()*3)+1,1,5); return [g, clamp(Math.floor(rand()*g),0,g-1)]; };
  const drawScore = () => { const g=Math.floor(rand()*3);              return [g, g]; };
  const lossScore = () => { const g=clamp(Math.floor(rand()*3)+1,1,5); return [clamp(Math.floor(rand()*g),0,g-1), g]; };

  const matches = [];
  for (let i=0;i<hw;i++) { const [gf,ga]=winScore();  matches.push({ha:'H',result:'W',gf,ga,homeTeam:team,awayTeam:'TBD',isHome:true}); }
  for (let i=0;i<aw;i++) { const [gf,ga]=winScore();  matches.push({ha:'A',result:'W',gf,ga,homeTeam:'TBD',awayTeam:team,isHome:false}); }
  for (let i=0;i<hd;i++) { const [gf,ga]=drawScore(); matches.push({ha:'H',result:'D',gf,ga,homeTeam:team,awayTeam:'TBD',isHome:true}); }
  for (let i=0;i<ad;i++) { const [gf,ga]=drawScore(); matches.push({ha:'A',result:'D',gf,ga,homeTeam:'TBD',awayTeam:team,isHome:false}); }
  for (let i=0;i<hl;i++) { const [gf,ga]=lossScore(); matches.push({ha:'H',result:'L',gf,ga,homeTeam:team,awayTeam:'TBD',isHome:true}); }
  for (let i=0;i<al;i++) { const [gf,ga]=lossScore(); matches.push({ha:'A',result:'L',gf,ga,homeTeam:'TBD',awayTeam:team,isHome:false}); }

  // Fisher-Yates shuffle (seeded)
  for (let i=matches.length-1;i>0;i--) {
    const j=Math.floor(rand()*(i+1));
    [matches[i],matches[j]]=[matches[j],matches[i]];
  }
  return matches;
}

